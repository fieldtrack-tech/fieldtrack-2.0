# =============================================================================
# FieldTrack 2.0 — API Environment Configuration
#
# Copy this file to .env and fill in real values for local development.
# In staging/production, inject these via Docker secrets or your secrets
# manager — NEVER commit a populated .env file to version control.
#
# All variables are validated at startup via Zod (src/config/env.ts).
# Missing or invalid variables cause an immediate, descriptive startup failure
# listing every broken field with a fix suggestion.
#
# Variable categories:
#   CONFIG VERSIONING   — schema version guard
#   RUNTIME ENVIRONMENT — APP_ENV, NODE_ENV, PORT
#   APPLICATION URLS    — APP_BASE_URL, API_BASE_URL, FRONTEND_BASE_URL
#   CORS                — CORS_ORIGIN
#   SUPABASE            — URL, keys, JWT secret
#   REDIS               — connection URL
#   SECURITY            — metrics scrape token
#   OBSERVABILITY       — Tempo, service name, commit SHA
#   HTTP LIMITS         — body size, timeout
#   WORKER LIMITS       — queue depth, GPS points, concurrency
# =============================================================================


# -----------------------------------------------------------------------------
# CONFIG VERSIONING
# -----------------------------------------------------------------------------

# Explicit configuration schema version.
# Must be the exact string "1". Any other value causes an immediate startup
# failure, catching deployments that carry a stale or mismatched .env.
#
# Bump this value (and the z.literal() in env.ts) whenever a breaking change
# is made to the required env variable set, so CI/CD pipelines and operators
# are forced to acknowledge the change before deploying.
#
# Default: "1" (so existing deployments without this variable are unaffected).
CONFIG_VERSION=1


# -----------------------------------------------------------------------------
# RUNTIME ENVIRONMENT
# -----------------------------------------------------------------------------

# Canonical application environment.
# Drives ALL environment-specific logic in the app (route guards, log
# verbosity, production safety checks, CORS fallback behaviour).
# Use this — not NODE_ENV — in application code.
#
# Valid values: development | staging | production | test
# Default: mirrors NODE_ENV if APP_ENV is unset (backward compat with
#          existing Dockerfiles that only set NODE_ENV=production).
APP_ENV=development

# Standard Node.js environment (kept for npm/library ecosystem compatibility).
# Fastify, pino, and other packages read this for their own optimisations.
# Should mirror APP_ENV in most cases.
# The Dockerfile bakes NODE_ENV=production; runtime deployments should also
# set APP_ENV=production explicitly.
NODE_ENV=development

# TCP port the Fastify server listens on inside the container.
# Map to a host port externally:  docker run -p 3000:3000 ...
#
# Range: 1000–65535 (ports < 1000 require root privileges).
# Default: 3000
PORT=3000


# -----------------------------------------------------------------------------
# APPLICATION URLS
# -----------------------------------------------------------------------------
# All URL fields are normalised at parse time — trailing slashes are stripped
# automatically to prevent double-slash bugs when concatenating paths:
#
#   API_BASE_URL=https://api.fieldtrack.com/   ← operator sets trailing slash
#   ${env.API_BASE_URL}/v1/users              → .../api.fieldtrack.com/v1/users ✅
#
# Format: full URL including protocol, NO trailing slash.
# -----------------------------------------------------------------------------

# Canonical base URL for the entire application.
# Use this as the single source of truth for generating absolute links that
# do not need to distinguish between the API and the frontend (e.g. email
# footers, canonical <link> headers, generic redirects).
#
# Required in production (APP_ENV=production) — startup fails if unset.
#
# Examples:
#   Production:  APP_BASE_URL=https://fieldtrack.com
#   Staging:     APP_BASE_URL=https://staging.fieldtrack.com
#   Local:       APP_BASE_URL=http://localhost:3000
APP_BASE_URL=

# Fully-qualified base URL of this API service.
# Used for:
#   - OpenAPI / Swagger server list (so "Try it out" targets the right host)
#   - Any server-generated absolute link that references the API itself
#
# Required in production (APP_ENV=production) — startup fails if unset.
#
# Examples:
#   Production:  API_BASE_URL=https://api.fieldtrack.com
#   Staging:     API_BASE_URL=https://api-staging.fieldtrack.com
#   Local:       (leave unset — Swagger UI falls back to http://localhost:<PORT>)
API_BASE_URL=

# Fully-qualified base URL of the frontend application.
# Used for:
#   - Password-reset email links:  ${FRONTEND_BASE_URL}/reset-password?token=…
#   - Invitation email links:      ${FRONTEND_BASE_URL}/accept-invite?token=…
#   - Any server-generated redirect that lands the user back in the UI
#
# Required in production (APP_ENV=production) — startup fails if unset.
#
# Examples:
#   Production:  FRONTEND_BASE_URL=https://app.fieldtrack.com
#   Staging:     FRONTEND_BASE_URL=https://staging.fieldtrack.com
#   Local:       FRONTEND_BASE_URL=http://localhost:3000
FRONTEND_BASE_URL=http://localhost:3000


# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
# The CORS plugin NEVER uses a wildcard origin (origin: true / "*").
# Origin resolution is fully deterministic across all environments:
#
#   Priority 1 — CORS_ORIGIN is set (non-empty):
#     → The parsed list is used in every environment.
#     → Set this explicitly even in development if you need a non-standard port.
#
#   Priority 2 — CORS_ORIGIN is empty AND APP_ENV === "development":
#     → Falls back to hardcoded safe list: localhost:3000 + localhost:5173
#       (standard ports for Create React App and Vite respectively).
#     → This is a compile-time constant in cors.plugin.ts, not a wildcard.
#
#   Priority 3 — CORS_ORIGIN is empty AND APP_ENV !== "development":
#     → Blocked at startup by env.ts superRefine — server will not start.
# -----------------------------------------------------------------------------

# Comma-separated list of origins allowed to make cross-origin requests.
#
# Leave EMPTY in development to activate the automatic dev fallback
# (localhost:3000 + localhost:5173) — no wildcard is ever used.
#
# Must be non-empty in production — startup fails if it is empty there.
#
# Examples:
#   Single origin:    CORS_ORIGIN=https://app.fieldtrack.com
#   Multiple origins: CORS_ORIGIN=https://app.fieldtrack.com,https://admin.fieldtrack.com
#   Local override:   CORS_ORIGIN=http://localhost:4000
CORS_ORIGIN=


# -----------------------------------------------------------------------------
# SUPABASE
# -----------------------------------------------------------------------------

# Your Supabase project URL.
# Found in: Supabase Dashboard → Project Settings → API → Project URL
# Example: https://xyzcompany.supabase.co
SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous (public) key.
# Safe to expose to browsers. Row Level Security is enforced for this key.
# Found in: Supabase Dashboard → Project Settings → API → anon public
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase service role key.
# NEVER expose this to clients or commit it to version control.
# Bypasses Row Level Security — used exclusively by the backend for
# privileged database operations.
# Found in: Supabase Dashboard → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase JWT signing secret (HS256).
# Used by @fastify/jwt in test mode to sign and verify test tokens.
# Must be at least 32 characters.
# Found in: Supabase Dashboard → Project Settings → API → JWT Settings → JWT Secret
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-minimum-32-characters


# -----------------------------------------------------------------------------
# REDIS
# -----------------------------------------------------------------------------

# Full Redis connection URL used by BullMQ workers and the rate-limit store.
#
# Scheme:
#   redis://   — plain TCP (local dev, private network)
#   rediss://  — TLS-encrypted (managed Redis: Redis Cloud, Upstash, ElastiCache)
#
# The URL is validated at startup — the server will not start if the prefix
# is wrong (e.g. a bare "host:port" string will be rejected with a clear error).
#
# Examples:
#   Local Docker:     REDIS_URL=redis://redis:6379
#   Local bare:       REDIS_URL=redis://localhost:6379
#   With password:    REDIS_URL=redis://:yourpassword@redis.example.com:6379
#   With TLS:         REDIS_URL=rediss://user:password@redis-tls.example.com:6380
#
# ⚠️  Never log REDIS_URL — it may contain a password in the connection string.
REDIS_URL=redis://localhost:6379


# -----------------------------------------------------------------------------
# SECURITY
# -----------------------------------------------------------------------------

# Bearer token Prometheus must present when scraping /metrics.
#
# When set:  GET /metrics requires "Authorization: Bearer <token>"
# When unset: /metrics is open (acceptable in development, forbidden in prod)
#
# Required in production — startup fails if missing when APP_ENV=production.
#
# Generate a strong token: openssl rand -hex 32
# Configure the same value in prometheus.yml scrape_configs:
#   authorization:
#     credentials: <METRICS_SCRAPE_TOKEN>
#
# ⚠️  Never log this value.
METRICS_SCRAPE_TOKEN=


# -----------------------------------------------------------------------------
# OBSERVABILITY — OpenTelemetry / Grafana Tempo
# -----------------------------------------------------------------------------

# OTLP HTTP endpoint for exporting traces to Grafana Tempo.
#
# Default resolves via Docker service name on fieldtrack_network.
# Override for non-Docker deployments, external Tempo, or cloud OTLP ingest.
#
# Note: bare Docker service hostnames (e.g. "tempo") are intentionally
# accepted — strict URL validators reject them because they lack a TLD.
#
# Examples:
#   Docker (default):  TEMPO_ENDPOINT=http://tempo:4318
#   External Tempo:    TEMPO_ENDPOINT=https://tempo.example.com:4318
#   Grafana Cloud:     TEMPO_ENDPOINT=https://otlp-gateway-prod-eu-west-0.grafana.net/otlp
TEMPO_ENDPOINT=http://tempo:4318

# OpenTelemetry service name shown in Grafana Tempo and the service graph.
# Change this per deployment if you run multiple FieldTrack environments
# side-by-side in the same Tempo instance (e.g. fieldtrack-staging-backend).
# Default: fieldtrack-backend
SERVICE_NAME=fieldtrack-backend

# Git commit SHA — injected automatically by GitHub Actions as GITHUB_SHA.
# Logged on server boot so operators can correlate a running container to
# an exact git commit. Leave unset for local development (logs as "manual").
# GITHUB_SHA=


# -----------------------------------------------------------------------------
# HTTP LIMITS
# -----------------------------------------------------------------------------

# Maximum allowed request body size in bytes.
# Protects against large-payload denial-of-service attacks.
# Increase only for endpoints that legitimately handle large uploads.
# Default: 1000000 (1 MB)
BODY_LIMIT_BYTES=1000000

# Maximum time in milliseconds Fastify waits for a response before closing
# the connection. Prevents slow-response resource exhaustion.
# Default: 30000 (30 seconds)
REQUEST_TIMEOUT_MS=30000


# -----------------------------------------------------------------------------
# WORKER LIMITS — Distance recalculation (BullMQ)
# -----------------------------------------------------------------------------

# Maximum number of distance-recalculation jobs that may wait in the BullMQ
# queue before new enqueues are rejected.
# Guards against runaway session creation flooding Redis.
# Default: 1000
MAX_QUEUE_DEPTH=1000

# Maximum GPS point count per session before the recalculation job is
# rejected. Guards against pathological data saturating the event loop.
# Default: 50000
MAX_POINTS_PER_SESSION=50000

# Sessions longer than this many hours are treated as data-integrity anomalies
# and are skipped during recalculation (e.g. an accidentally un-closed session).
# Default: 168 (7 days)
MAX_SESSION_DURATION_HOURS=168

# Number of distance recalculation jobs the distance worker processes
# concurrently per replica. Default 1 ensures sequential, predictable
# processing. Increase with care — each concurrent job hits the database.
# Default: 1
WORKER_CONCURRENCY=1

# Number of analytics aggregation jobs the analytics worker processes
# concurrently per replica.
#
# Range: 1–50.
#   Lower values reduce database connection pressure.
#   Higher values speed up post-checkout metric aggregation under load.
#   Values above 50 shift the bottleneck to the database and risk
#   overwhelming the connection pool — hence the hard cap.
#
# Default: 5
ANALYTICS_WORKER_CONCURRENCY=5
