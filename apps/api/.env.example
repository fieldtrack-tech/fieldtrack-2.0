# FieldTrack 2.0 — Backend Environment Variables
# Copy this file to .env and fill in the values

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
PORT=3000
NODE_ENV=production

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ============================================================================
# REDIS CONFIGURATION
# ============================================================================
REDIS_URL=redis://localhost:6379

# ============================================================================
# SECURITY CONFIGURATION
# ============================================================================

# Comma-separated list of allowed CORS origins
ALLOWED_ORIGINS=https://fieldtrack.meowsician.tech,https://www.fieldtrack.meowsician.tech

# Prometheus metrics scrape token (REQUIRED in production)
# Generate with: openssl rand -hex 32
METRICS_SCRAPE_TOKEN=your-secure-random-token-here

# ============================================================================
# DOMAIN CONFIGURATION
# ============================================================================
API_DOMAIN=api.fieldtrack.meowsician.tech
FRONTEND_DOMAIN=fieldtrack.meowsician.tech

# ============================================================================
# OBSERVABILITY CONFIGURATION
# ============================================================================

# Tempo OTLP endpoint for distributed tracing (optional)
# TEMPO_ENDPOINT=http://tempo:4318/v1/traces

# ============================================================================
# WORKER CONFIGURATION
# ============================================================================

# Maximum number of sessions in worker queue
MAX_QUEUE_DEPTH=1000

# Maximum GPS points per session before rejection
MAX_POINTS_PER_SESSION=50000

# Maximum session duration in hours
MAX_SESSION_DURATION_HOURS=168

# Number of concurrent worker jobs (default: 1)
WORKER_CONCURRENCY=1

# ============================================================================
# HTTP LIMITS (EXTERNALIZED)
# ============================================================================

# Maximum request body size in bytes (default: 1MB)
BODY_LIMIT_BYTES=1000000

# Request timeout in milliseconds (default: 30s)
REQUEST_TIMEOUT_MS=30000

# ============================================================================
# DEPLOYMENT CONFIGURATION (for deploy scripts)
# ============================================================================

# Root directory for deployment (REQUIRED for deploy-bluegreen.sh)
# export DEPLOY_ROOT=/home/ashish/FieldTrack-2.0
