# FieldTrack 2.0 Backend — Environment Variables
# Copy this file to .env and fill in all required values before starting the server.

# ── Server ─────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Supabase ───────────────────────────────────────────────────────────────────
# Supabase project URL (e.g. https://xxxxxxxxxxxxxxxxxxxx.supabase.co)
SUPABASE_URL=

# Service role key — grants full database access; never expose to clients
SUPABASE_SERVICE_ROLE_KEY=

# Anon key — safe for client-side; used for Supabase JS client initialisation
SUPABASE_ANON_KEY=

# JWT secret — must match the "JWT Secret" in your Supabase project settings
SUPABASE_JWT_SECRET=

# ── Redis ──────────────────────────────────────────────────────────────────────
# Full Redis connection URL (redis:// or rediss:// for TLS)
# Example: redis://127.0.0.1:6379
REDIS_URL=

# ── CORS ───────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. Leave empty to block all cross-origin requests.
# Example: https://app.yourdomain.com,https://admin.yourdomain.com
ALLOWED_ORIGINS=

# ── Observability ──────────────────────────────────────────────────────────────
# Tempo OTLP HTTP endpoint for distributed tracing (optional; tracing disabled if unset)
# Example: http://localhost:4318
TEMPO_ENDPOINT=

# ── Worker Safety Limits (optional — defaults shown as comments) ───────────────
# MAX_QUEUE_DEPTH=1000
# MAX_POINTS_PER_SESSION=50000
# MAX_SESSION_DURATION_HOURS=168
# WORKER_CONCURRENCY=1
